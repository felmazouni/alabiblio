{
  "name": "alabiblio",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "pnpm build:web && pnpm build:edge",
    "build:web": "pnpm --dir apps/web build",
    "build:edge": "pnpm --dir workers/edge build",
    "preview:local": "pnpm build:web && pnpm --dir workers/edge dev",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:edge": "pnpm --dir workers/edge dev",
    "test": "vitest run",
    "typecheck": "pnpm typecheck:contracts && pnpm typecheck:domain && pnpm typecheck:application && pnpm typecheck:infrastructure && pnpm typecheck:web && pnpm typecheck:edge",
    "typecheck:contracts": "pnpm --dir packages/contracts typecheck",
    "typecheck:domain": "pnpm --dir packages/domain typecheck",
    "typecheck:application": "pnpm --dir packages/application typecheck",
    "typecheck:infrastructure": "pnpm --dir packages/infrastructure typecheck",
    "typecheck:web": "pnpm --dir apps/web typecheck",
    "typecheck:edge": "pnpm --dir workers/edge typecheck"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
