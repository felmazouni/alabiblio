{
  "name": "alabiblio",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "node scripts/run-workspace-script.mjs apps/web dev",
    "build": "node scripts/run-workspace-script.mjs apps/web build",
    "preview": "node scripts/run-workspace-script.mjs apps/web preview",
    "deploy:staging": "node scripts/run-workspace-script.mjs apps/web deploy:staging",
    "deploy:production": "node scripts/run-workspace-script.mjs apps/web deploy:production",
    "typecheck": "node scripts/run-workspace-script.mjs apps/web typecheck",
    "lint": "node scripts/run-workspace-script.mjs apps/web lint",
    "test": "tsx --test tests/**/*.test.ts tests/**/*.test.mjs",
    "cf-typegen": "node scripts/run-workspace-script.mjs apps/web cf-typegen",
    "db:migrate:local": "tsx scripts/apply-migrations.ts local",
    "db:migrate:staging": "tsx scripts/apply-migrations.ts staging",
    "db:migrate:production": "tsx scripts/apply-migrations.ts production",
    "db:seed:local": "tsx scripts/apply-seeds.ts local",
    "db:seed:staging": "tsx scripts/apply-seeds.ts staging",
    "db:seed:production": "tsx scripts/apply-seeds.ts production",
    "ingest:centers:local": "tsx scripts/ingest-centers.ts local",
    "ingest:centers:staging": "tsx scripts/ingest-centers.ts staging",
    "ingest:centers:production": "tsx scripts/ingest-centers.ts production",
    "sync:mobility:local": "tsx scripts/sync-mobility.ts local",
    "sync:mobility:staging": "tsx scripts/sync-mobility.ts staging",
    "sync:mobility:production": "tsx scripts/sync-mobility.ts production",
    "sync:ser:local": "tsx scripts/sync-ser.ts local",
    "sync:ser:staging": "tsx scripts/sync-ser.ts staging",
    "sync:ser:production": "tsx scripts/sync-ser.ts production",
    "ingest:callejero:local": "tsx scripts/ingest-callejero.ts local",
    "ingest:callejero:staging": "tsx scripts/ingest-callejero.ts staging",
    "ingest:callejero:production": "tsx scripts/ingest-callejero.ts production",
    "smoke:staging": "tsx scripts/smoke-public.ts https://staging.alabiblio.org",
    "smoke:production": "tsx scripts/smoke-public.ts https://alabiblio.org"
  },
  "devDependencies": {
    "csv-parse": "^6.2.1",
    "he": "^1.2.0",
    "shpjs": "^6.2.0",
    "tsx": "^4.21.0"
  }
}
