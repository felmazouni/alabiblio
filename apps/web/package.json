{
	"name": "web",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"build": "tsc -b && vite build",
		"typecheck": "tsc -b",
		"lint": "eslint src worker vite.config.ts eslint.config.js",
		"preview": "wrangler dev",
		"deploy:staging": "wrangler deploy --config wrangler.jsonc --env staging",
