		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@alabiblio/contracts": "workspace:*",
		"@alabiblio/domain": "workspace:*",
		"@alabiblio/geo": "workspace:*",
		"@alabiblio/mobility": "workspace:*",
		"@alabiblio/schedule-engine": "workspace:*",
		"@alabiblio/ui": "workspace:*",
		"framer-motion": "^12.38.0",
		"gsap": "^3.14.2",
		"lucide-react": "^1.7.0",
		"maplibre-gl": "^5.21.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router-dom": "^7.13.2"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.30.2",
		"@eslint/js": "^9.39.1",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"typescript": "~5.9.3",
