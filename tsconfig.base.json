{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@alabiblio/contracts/*": [
        "packages/contracts/src/*"
      ],
      "@alabiblio/domain/*": [
        "packages/domain/src/*"
      ],
      "@alabiblio/geo/*": [
        "packages/geo/src/*"
      ],
      "@alabiblio/ingestion/*": [
        "packages/ingestion/src/*"
      ],
      "@alabiblio/mobility/*": [
        "packages/mobility/src/*"
      ],
      "@alabiblio/schedule-engine/*": [
        "packages/schedule-engine/src/*"
      ],
      "@alabiblio/ui/*": [
        "packages/ui/src/*"
      ]
    }
  }
}
